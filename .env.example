# Copy this file to .env and fill the real values locally.
# Never commit a real Telegram token.

TELEGRAM_BOT_TOKEN=123456789:replace_with_your_bot_token
TELEGRAM_ADMIN_CHAT_ID=123456789
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_WEBHOOK_SECRET=replace_with_long_random_secret

ANALYTICS_OWNER_SECRET=replace_with_long_random_owner_secret
ANALYTICS_TIMEZONE=Asia/Jerusalem
TELEGRAM_NOTIFY_VISITS=false

SITE_PUBLIC_URL=https://your-netlify-site.netlify.app
